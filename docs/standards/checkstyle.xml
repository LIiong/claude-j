<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    claude-j 项目 Checkstyle 规则
    用于自动化执行 java-dev.md 中的编码规范
    运行: mvn checkstyle:check
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <module name="TreeWalker">

        <!-- ==================== Java 8 兼容性守护 ==================== -->

        <!-- 禁止 var 关键字 (Java 10+) — 通过正则检查 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s+var\s+\w+\s*="/>
            <property name="message" value="禁止使用 var 关键字（Java 8 兼容要求）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 text blocks (Java 13+) -->
        <module name="RegexpSinglelineJava">
            <property name="format" value='&quot;&quot;&quot;'/>
            <property name="message" value="禁止使用 text blocks（Java 8 兼容要求）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 List.of / Map.of / Set.of (Java 9+) -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\bList\.of\s*\("/>
            <property name="message" value="禁止 List.of()，使用 Arrays.asList()（Java 8 兼容要求）"/>
            <property name="ignoreComments" value="true"/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="format" value="\bMap\.of\s*\("/>
            <property name="message" value="禁止 Map.of()（Java 8 兼容要求）"/>
            <property name="ignoreComments" value="true"/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="format" value="\bSet\.of\s*\("/>
            <property name="message" value="禁止 Set.of()（Java 8 兼容要求）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- ==================== 命名规范 ==================== -->

        <!-- 常量: UPPER_SNAKE_CASE -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$|^log$|^serialVersionUID$"/>
        </module>

        <!-- 方法: camelCase -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 包名: 小写 -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- ==================== 基本代码质量 ==================== -->

        <!-- 禁止 * import -->
        <module name="AvoidStarImport"/>

        <!-- 禁止未使用的 import -->
        <module name="UnusedImports"/>

        <!-- 禁止空 catch 块 -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignored"/>
        </module>

        <!-- 大括号必须使用 -->
        <module name="NeedBraces"/>

    </module>

    <!-- 文件级检查 -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

</module>
